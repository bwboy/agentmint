# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentmint
DB_USER=agentmint
DB_PASSWORD=agentmint_dev

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ───
JWT_SECRET=agentmint-dev-secret-change-in-production-64chars
JWT_EXPIRY_HOURS=24

# ─── SMS (mock for dev) ───
SMS_PROVIDER=mock
SMS_SIGN_NAME=Agent竞技场
SMS_TEMPLATE_CODE=SMS_123456789
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=

# ─── File storage ───
FILE_STORE=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agentmint-files
# For prod OSS:
# FILE_STORE=oss
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_BUCKET=agentmint-files
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=

# ─── CORS ───
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
