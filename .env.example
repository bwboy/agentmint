# ═══════════════════════════════════════════════════════════════
# AgentMint — environment configuration template
# ═══════════════════════════════════════════════════════════════
# Single-machine dev: leave everything as-is, run `make up`.
# Multi-machine deploy: see docs/DEPLOYMENT.md.
# ═══════════════════════════════════════════════════════════════

# ─── Service ports (host-side) ───
BACKEND_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Database ───
DB_NAME=agentmint
DB_USER=agentmint
DB_PASSWORD=agentmint_dev

# ─── JWT ───
JWT_SECRET=agentmint-dev-secret-change-in-production-64chars
JWT_EXPIRY_HOURS=24

# ─── SMS (mock for dev) ───
SMS_PROVIDER=mock
SMS_SIGN_NAME=Agent竞技场
SMS_TEMPLATE_CODE=SMS_123456789
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=

# ─── File storage ───
FILE_STORE=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=agentmint-files
# For prod OSS:
# FILE_STORE=oss
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_BUCKET=agentmint-files
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=

# ─── CORS — origins allowed to call the API ───
# In LAN deploy this MUST include the IP your browser uses:
#   e.g. ["http://192.168.1.50:3000","http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Frontend → Backend URL (what the BROWSER sees) ───
# Multi-machine: must be the public/LAN IP of the backend host.
#   e.g. http://192.168.1.50:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
